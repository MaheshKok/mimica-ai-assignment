# Enriched QA Service configuration.
# Copy to `.env` and adjust for your environment.
# Defaults match app/config.py (added in Phase 2).

# Upstream services
WORKFLOW_API_URL=http://localhost:9000
STORAGE_BASE_URL=http://localhost:9100
STORAGE_BUCKET=mimica-screenshots

# Concurrency / back-pressure
MAX_CONCURRENT_FETCHES=25
GLOBAL_FETCH_CONCURRENCY=100

# Ranker
MAX_RELEVANT_IMAGES=20
MAX_RANK_INPUT=500
FILTER_WORKERS=

# Partial-failure policy
MAX_FETCH_FAILURE_RATIO=0.2

# Stream assumption
ASSUME_SORTED_STREAM=true

# Request budget
REQUEST_TIMEOUT_MS=15000

# Observability (unset -> console exporter)
OTEL_EXPORTER_OTLP_ENDPOINT=
